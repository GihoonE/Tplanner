// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id               Int    @id @default(autoincrement())
  name             String
  subject          String
  grade            String
  school           String
  color            String // s-blue, s-teal, etc.
  avatarChar       String
  status           String // active, inactive
  startDate        String // "2024-09"
  totalSessions    Int    @default(0)
  hwCompletionRate Int    @default(0)
  instructorId     String?
  instructor       User?  @relation("InstructorStudents", fields: [instructorId], references: [id], onDelete: Cascade)
  sessions         LessonSession[]
  reports          Report[]
  parentLinks      StudentParent[]
  invitations      StudentInvitation[]

  @@index([instructorId, status, id])
}


// FK studentId references student(id)
// 그러나 @relation은 참조하는 왜래키 컬럼이 아니라 관계있는 필드와 연결지어준다
model LessonSession {
  id           Int       @id @default(autoincrement())
  studentId    Int?
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  start        DateTime
  end          DateTime
  place        String    @default("")
  notes        String    @default("")
  understanding String   @default("") // good, normal, hard
  focus        String    @default("") // high, normal, low
  version      Int       @default(1)
  homework     HomeworkItem[]
  reportSessions ReportSession[]

  @@index([studentId, start])
  @@index([start])
  @@index([end])
  @@index([studentId, start, end])
  @@map("Session")
}

model SessionBatchCreateRequest {
  key       String   @id
  userId    String
  response  Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model HomeworkItem {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean @default(false)

  @@index([sessionId])
}

model Report {
  id           Int             @id @default(autoincrement())
  studentId    Int
  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title        String
  status       String          @default("draft") // draft, sent
  periodStart  DateTime?
  periodEnd    DateTime?
  summary      String          @default("")
  strengths    String          @default("")
  improvements String          @default("")
  nextPlan     String          @default("")
  sessions     ReportSession[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([studentId, updatedAt, id])
}

model ReportSession {
  reportId  Int
  sessionId Int
  report    Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  session   LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([reportId, sessionId])
  @@index([sessionId])
}

model AppPreference {
  id              Int      @id @default(1)
  primaryTimezone String   @default("Asia/Seoul")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserPreference {
  userId          String   @id
  primaryTimezone String   @default("Asia/Seoul")
  extraTimezones  Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String?   // instructor, parent
  accounts      Account[]
  sessions      Session[]
  students      Student[] @relation("InstructorStudents")
  parentLinks   StudentParent[]
  invitations   StudentInvitation[]
  preference    UserPreference?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AuthSession")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model StudentParent {
  studentId Int
  parentId  String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    User     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  linkedAt  DateTime @default(now())

  @@id([studentId, parentId])
  @@index([parentId, studentId])
}

model StudentInvitation {
  id           Int       @id @default(autoincrement())
  studentId    Int
  instructorId String
  codeHash     String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor   User      @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([studentId, instructorId, createdAt])
  @@index([instructorId, createdAt])
}
